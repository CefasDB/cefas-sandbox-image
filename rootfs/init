#!/bin/sh
# PID 1 for the Try CefasDB sandbox.
#
# Mounts the pseudo-filesystems Linux expects, starts cefas-server in
# the background so the user lands in a shell with a live server,
# prints a brief welcome, then execs an interactive sh on the console.
set -eu

/bin/busybox --install -s /bin >/dev/null 2>&1 || true

mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev || mdev -s
mount -t tmpfs    tmpfs    /tmp

hostname cefas-sandbox

mkdir -p /data

# The cefas binaries are baked in only when CEFAS_TOKEN was set at
# build time. When absent, the user lands in a Linux shell with
# busybox alone — useful for proving the V86 boot path itself.
if [ ! -x /usr/bin/cefas ] && [ ! -x /usr/sbin/cefas-server ]; then
  touch /etc/cefas/no-binary
fi

if [ -x /usr/sbin/cefas-server ]; then
  ( cefas-server -config /etc/cefas/server.toml > /tmp/cefas-server.log 2>&1 ) &
  i=0
  while [ $i -lt 30 ]; do
    if cefas status >/dev/null 2>&1; then break; fi
    sleep 0.2
    i=$((i + 1))
  done
else
  : > /tmp/cefas-server.log
  echo "cefas-server not present in this image — CLI-only sandbox" \
    > /etc/cefas/no-server
fi

clear || true
cat /etc/motd

export HOME=/root
export PS1='cefas-sandbox:\w$ '
cd /root

# Respawn the shell forever — PID 1 must not exit or the kernel panics
# and reboots. setsid + cttyhack aren't in the static busybox we ship,
# so we wire stdio to /dev/console explicitly and run sh -i.
while true; do
  </dev/console >/dev/console 2>&1 /bin/sh -i
  echo
  echo '[init] shell exited; respawning…'
  sleep 1
done
